@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="border-b">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-3 font-bold">MehguViewer</MudText>
        <MudSpacer />
        <MudLink Href="https://proto.mehguviewer.kazeo.xyz" Target="_blank" Color="Color.Inherit" Class="mr-4 text-muted">Documentation</MudLink>
        <MudAvatar Color="Color.Secondary" Variant="Variant.Outlined">A</MudAvatar>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Class="border-r">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<style>
    .border-b { border-bottom: 1px solid var(--mud-palette-lines-default); }
    .border-r { border-right: 1px solid var(--mud-palette-lines-default); }
    .text-muted { color: var(--mud-palette-text-secondary) !important; }
    .font-bold { font-weight: 700; }
</style>

@code {
    bool _drawerOpen = true;
    private MudTheme _theme = new();

    protected override void OnInitialized()
    {
        _theme = new MudTheme()
        {
            PaletteDark = new PaletteDark()
            {
                Primary = "#fafafa",
                PrimaryContrastText = "#18181b",
                Secondary = "#27272a",
                SecondaryContrastText = "#fafafa",
                Tertiary = "#27272a",
                Background = "#09090b",
                AppbarBackground = "#09090b",
                DrawerBackground = "#09090b",
                Surface = "#09090b",
                TextPrimary = "#fafafa",
                TextSecondary = "#a1a1aa",
                ActionDefault = "#fafafa",
                ActionDisabled = "#27272a",
                ActionDisabledBackground = "#27272a",
                Divider = "#27272a",
                DividerLight = "#27272a",
                TableLines = "#27272a",
                LinesDefault = "#27272a",
                OverlayDark = "rgba(0,0,0,0.5)",
                Error = "#7f1d1d"
            },
            Typography = new Typography()
            {
                /* Default = new()
                {
                    FontFamily = new[] { "-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif" }
                } */
            }
        };
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}
