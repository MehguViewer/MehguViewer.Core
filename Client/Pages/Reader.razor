@page "/read/{SeriesUrn}/{UnitId}"
@using System.Text.Json
@using System.Text.Json.Serialization
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Reader - MehguViewer</PageTitle>

<div class="reader-container">
    @if (pages == null)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading pages...</p>
        </div>
    }
    else if (pages.Count == 0)
    {
        <div class="empty-state">
            <p>No pages found in this chapter.</p>
            <button class="btn btn-secondary" @onclick="GoBack">Back to Series</button>
        </div>
    }
    else
    {
        <div class="reader-toolbar">
            <button class="btn btn-sm btn-secondary" @onclick="GoBack">
                <span class="icon">⬅️</span> Back
            </button>
            <span class="page-indicator">Page @currentPage of @pages.Count</span>
            <div class="reader-controls">
                <button class="btn btn-sm btn-primary" @onclick="PrevPage" disabled="@(currentPage <= 1)">Prev</button>
                <button class="btn btn-sm btn-primary" @onclick="NextPage" disabled="@(currentPage >= pages.Count)">Next</button>
            </div>
        </div>

        <div class="reader-content" @onclick="HandleImageClick">
            @if (CurrentPageDto != null)
            {
                <img src="@CurrentPageDto.Url" alt="Page @CurrentPageDto.PageNumber" class="reader-image" />
            }
        </div>
    }
</div>

<style>
    .reader-container {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 60px); /* Adjust based on layout header */
        background-color: #1a1a1a;
    }

    .reader-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 20px;
        background-color: #2a2a2a;
        color: white;
    }

    .reader-content {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: auto;
        padding: 20px;
        cursor: pointer;
    }

    .reader-image {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        box-shadow: 0 4px 8px rgba(0,0,0,0.5);
    }
</style>

@code {
    [Parameter]
    public string SeriesUrn { get; set; } = "";

    [Parameter]
    public string UnitId { get; set; } = "";

    private List<PageDto>? pages;
    private int currentPage = 1;

    private PageDto? CurrentPageDto => pages?.FirstOrDefault(p => p.PageNumber == currentPage);

    protected override async Task OnInitializedAsync()
    {
        await LoadPages();
    }

    private async Task LoadPages()
    {
        try
        {
            pages = await Http.GetFromJsonAsync<List<PageDto>>($"api/v1/series/{SeriesUrn}/units/{UnitId}/pages");
            if (pages != null && pages.Count > 0)
            {
                pages = pages.OrderBy(p => p.PageNumber).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading pages: {ex.Message}");
            pages = new List<PageDto>();
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"library/{SeriesUrn}");
    }

    private async Task PrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await UpdateProgress();
        }
    }

    private async Task NextPage()
    {
        if (pages != null && currentPage < pages.Count)
        {
            currentPage++;
            await UpdateProgress();
        }
        else if (pages != null && currentPage == pages.Count)
        {
            // End of chapter
            // TODO: Navigate to next chapter if available
            Console.WriteLine("End of chapter");
        }
    }

    private async Task HandleImageClick(MouseEventArgs e)
    {
        // Simple click to next for now
        await NextPage();
    }

    private async Task UpdateProgress()
    {
        try
        {
            var progress = new ProgressUpdate
            {
                LastReadChapterId = UnitId,
                PageNumber = currentPage,
                Completed = pages != null && currentPage == pages.Count
            };
            
            await Http.PutAsJsonAsync($"api/v1/series/{SeriesUrn}/progress", progress);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating progress: {ex.Message}");
        }
    }

    public class PageDto
    {
        [JsonPropertyName("page_number")]
        public int PageNumber { get; set; }

        [JsonPropertyName("url")]
        public string Url { get; set; } = "";
    }

    public class ProgressUpdate
    {
        [JsonPropertyName("last_read_chapter_id")]
        public string LastReadChapterId { get; set; } = "";

        [JsonPropertyName("page_number")]
        public int PageNumber { get; set; }

        [JsonPropertyName("completed")]
        public bool Completed { get; set; }
    }
}
