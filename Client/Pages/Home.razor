@page "/"
@using System.Text.Json
@using System.Text.Json.Serialization
@inject HttpClient Http

<PageTitle>Dashboard - MehguViewer</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-4 text-muted">Overview of your MehguViewer node.</MudText>

@if (manifest == null)
{
    <div class="d-flex justify-center align-center pa-4">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        <MudText Class="ml-4">Connecting to node...</MudText>
    </div>
}
else
{
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Node Status</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="ml-auto">Online</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string" Dense="true">
                        <MudListItem>
                            <div class="d-flex justify-space-between">
                                <MudText Typo="Typo.body2">Node URN</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@manifest.Urn</MudText>
                            </div>
                        </MudListItem>
                        <MudListItem>
                            <div class="d-flex justify-space-between">
                                <MudText Typo="Typo.body2">Version</MudText>
                                <MudText Typo="Typo.body2">@manifest.Version</MudText>
                            </div>
                        </MudListItem>
                        <MudListItem>
                            <div class="d-flex justify-space-between">
                                <MudText Typo="Typo.body2">Maintainer</MudText>
                                <MudText Typo="Typo.body2">@manifest.Maintainer?.Name</MudText>
                            </div>
                        </MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Quick Actions</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <div class="d-flex gap-4 flex-wrap">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="wizard" StartIcon="@Icons.Material.Filled.AutoFixHigh">
                            Setup Wizard
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="admin/configuration" StartIcon="@Icons.Material.Filled.Settings">
                            Configuration
                        </MudButton>
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    private NodeManifest? manifest;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // In a real scenario, this would map to the actual JSON structure returned by /api/v1/instance
            // For now we use a simplified model matching the previous code
            // Note: The backend returns "maintainer": "admin@example.com" as a string in one place and object in another in the mock?
            // Let's check the backend code.
            // Backend SystemEndpoints.cs:
            // new NodeManifest(..., "admin@example.com", ...) -> maintainer is string
            // But the previous Home.razor had MaintainerInfo class.
            // Let's adjust to match the backend if possible, or handle the mismatch.
            // The backend returns a JSON where maintainer is a string.
            // Wait, let me check the backend model definition in Domain.cs
            // public record NodeManifest(..., string maintainer, ...);
            // So it is a string.
            
            // However, to keep it simple and working with the existing backend mock:
            var rawManifest = await Http.GetFromJsonAsync<JsonElement>("api/v1/instance");
            
            manifest = new NodeManifest
            {
                Urn = rawManifest.GetProperty("urn").GetString() ?? "",
                Version = rawManifest.GetProperty("version").GetString() ?? "",
                Maintainer = new MaintainerInfo 
                { 
                    Name = rawManifest.GetProperty("maintainer").GetString() ?? "Unknown" 
                }
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching manifest: {ex.Message}");
             // Fallback for demo if backend is not running
            manifest = new NodeManifest
            {
                Urn = "urn:mvn:node:demo",
                Version = "1.0.0-demo",
                Maintainer = new MaintainerInfo { Name = "Demo Admin" }
            };
        }
    }

    public class NodeManifest
    {
        public string Urn { get; set; } = "";
        public string Version { get; set; } = "";
        public MaintainerInfo? Maintainer { get; set; }
    }

    public class MaintainerInfo
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
    }
}
