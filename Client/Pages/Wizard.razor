@page "/wizard"
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Setup Wizard - MehguViewer</PageTitle>

<div class="content-header">
    <h1>Setup Wizard</h1>
    <p class="text-muted">Configure your MehguViewer node.</p>
</div>

<div class="wizard-container" style="max-width: 600px; margin: 0 auto;">
    <div class="steps mb-4" style="display: flex; justify-content: space-between; color: var(--muted-foreground);">
        <span class="@(step >= 1 ? "text-primary font-bold" : "")">1. Welcome</span>
        <span class="@(step >= 2 ? "text-primary font-bold" : "")">2. Admin Account</span>
        <span class="@(step >= 3 ? "text-primary font-bold" : "")">3. Finish</span>
    </div>

    <div class="card">
        <div class="card-body">
            @if (step == 1)
            {
                <h3>Welcome to MehguViewer</h3>
                <p class="mb-4">This wizard will help you configure your new MehguViewer node. We'll set up your administrator account and basic settings.</p>
                <div class="actions">
                    <button class="btn btn-primary" @onclick="NextStep">Get Started</button>
                </div>
            }
            else if (step == 2)
            {
                <h3>Create Admin Account</h3>
                <div class="form-group mb-3">
                    <label class="form-label">Username</label>
                    <input type="text" class="form-control" @bind="username" placeholder="admin" />
                </div>
                <div class="form-group mb-4">
                    <label class="form-label">Password</label>
                    <input type="password" class="form-control" @bind="password" placeholder="••••••••" />
                </div>
                <div class="actions flex gap-2">
                    <button class="btn btn-secondary" @onclick="PrevStep">Back</button>
                    <button class="btn btn-primary" @onclick="NextStep">Next</button>
                </div>
            }
            else if (step == 3)
            {
                <h3>Finish Setup</h3>
                <p class="mb-4">You are all set! Click Finish to go to the dashboard.</p>
                <div class="actions flex gap-2">
                    <button class="btn btn-secondary" @onclick="PrevStep">Back</button>
                    <button class="btn btn-success" @onclick="FinishSetup">Finish</button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private int step = 1;
    private string username = "";
    private string password = "";

    private void NextStep()
    {
        step++;
    }

    private void PrevStep()
    {
        step--;
    }

    private void FinishSetup()
    {
        // In a real app, we would post the data to the backend here.
        // await Http.PostAsJsonAsync("/api/v1/setup", new { username, password });
        Navigation.NavigateTo("/");
    }
}
