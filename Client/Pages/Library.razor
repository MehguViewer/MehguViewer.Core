@page "/library"
@using System.Text.Json
@using System.Text.Json.Serialization
@inject HttpClient Http

<PageTitle>Library - MehguViewer</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Library</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-4 text-muted">Manage your manga and comic series.</MudText>

<div class="d-flex gap-4 mb-4 align-center">
    <MudTextField @bind-Value="searchTerm" Placeholder="Search series..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Class="flex-grow-1" />
    <MudButton Variant="Variant.Outlined" OnClick="RefreshLibrary" StartIcon="@Icons.Material.Filled.Refresh">Refresh</MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="library/add" StartIcon="@Icons.Material.Filled.Add">Add</MudButton>
</div>

@if (seriesList == null)
{
    <div class="d-flex justify-center align-center pa-4">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        <MudText Class="ml-4">Loading library...</MudText>
    </div>
}
else if (seriesList.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="my-4">
        No series found in the library. <MudLink Href="library/add">Import Series</MudLink>
    </MudAlert>
}
else
{
    <MudGrid>
        @foreach (var series in FilteredSeries)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">@series.Title</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Class="mt-2">@series.MediaType</MudChip>
                        <MudText Typo="Typo.caption" Class="d-block mt-2 text-muted">@series.Urn</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@($"library/{series.Urn}")">Details</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<SeriesDto>? seriesList;
    private string searchTerm = "";

    private IEnumerable<SeriesDto> FilteredSeries =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? seriesList ?? new List<SeriesDto>()
            : (seriesList ?? new List<SeriesDto>()).Where(s => s.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await RefreshLibrary();
    }

    private async Task RefreshLibrary()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<SeriesListResponse>("api/v1/series");
            seriesList = response?.Data ?? new List<SeriesDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching library: {ex.Message}");
            seriesList = new List<SeriesDto>();
        }
    }

    public class SeriesListResponse
    {
        [JsonPropertyName("data")]
        public List<SeriesDto> Data { get; set; } = new();
    }

    public class SeriesDto
    {
        [JsonPropertyName("id")]
        public string Urn { get; set; } = "";

        [JsonPropertyName("title")]
        public string Title { get; set; } = "";

        [JsonPropertyName("media_type")]
        public string MediaType { get; set; } = "";
        
        [JsonPropertyName("description")]
        public string Description { get; set; } = "";
    }
}
