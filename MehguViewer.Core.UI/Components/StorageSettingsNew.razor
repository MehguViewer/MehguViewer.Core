    }

    .settings-group {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .group-title {
        font-size: 0.875rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.7);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0;
    }

    .group-desc {
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.5);
        margin: -0.5rem 0 0.5rem;
