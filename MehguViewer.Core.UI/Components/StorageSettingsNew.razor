        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
    }

    .stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-icon.primary {
        background: rgba(201, 166, 107, 0.15);
