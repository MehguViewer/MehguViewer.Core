    }

    .action-btn.primary {
        background: linear-gradient(135deg, #c9a66b, #8b6914);
        color: #fff;
    }

    .action-btn.primary:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(201, 166, 107, 0.35);
    }

    .action-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .dark-input ::deep .mud-input-outlined-border {
        border-color: rgba(255, 255, 255, 0.12) !important;
    }

    .dark-input ::deep .mud-input-outlined-border:hover {
        border-color: rgba(201, 166, 107, 0.4) !important;
    }

    .dark-input ::deep .mud-input-root {
        color: #fff !important;
    }
</style>

@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

@code {
    private long _totalStorage = 1024 * 1024 * 500; // 500MB mock
    private long _maxStorage = 1024L * 1024 * 1024 * 10; // 10GB mock
    private int _assetCount = 1234;
    private long _cacheSize = 1024 * 1024 * 50; // 50MB mock
    private string _storagePath = "/var/lib/mehguviewer/storage";
    private int _thumbnailSize = 200;
    private int _webSize = 1200;
    private int _jpegQuality = 85;

    private double _storagePercentage => ((double)_totalStorage / _maxStorage) * 100;

    private string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private async Task ClearCache()
    {
        // TODO: Implement cache clearing
        Snackbar.Add("Cache cleared successfully", Severity.Success);
    }

    private async Task CopyPath()
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _storagePath);
        Snackbar.Add("Path copied to clipboard", Severity.Info);
    }
}
