    }

    .copy-btn {
        padding: 0.375rem;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.4);
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s;
    }

    .copy-btn:hover {
        color: #c9a66b;
        background: rgba(201, 166, 107, 0.1);
    }

    .info-banner {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        background: rgba(59, 130, 246, 0.1);
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 10px;
        color: rgba(255, 255, 255, 0.7);
