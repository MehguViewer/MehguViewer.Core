@page "/series/{SeriesId}/details"
@inject HttpClient Http
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

@using MehguViewer.Shared.Models

<PageTitle>@(_series?.title ?? "Series Details") - MehguViewer Core</PageTitle>

<div class="details-page">
    @if (_loading)
    {
        <div class="loading-container">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body2" Class="mt-2">Loading series details...</MudText>
        </div>
    }
    else if (_series == null)
    {
        <div class="empty-state">
            <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" />
            <MudText Typo="Typo.h6" Class="mt-2">Series not found</MudText>
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/series"))">
                Back to Library
            </MudButton>
        </div>
    }
    else
    {
        @* Back Navigation *@
        <div class="nav-row">
            <MudButton Variant="Variant.Text" 
                       StartIcon="@Icons.Material.Filled.ArrowBack" 
                       OnClick="@(() => Navigation.NavigateTo("/series"))"
                       Class="back-btn">
                Back to Library
            </MudButton>
        </div>

        <div class="details-content">
            @* Left Side: Cover Image *@
            <div class="cover-section">
                <div class="cover-wrapper">
                    @if (!string.IsNullOrEmpty(_series.poster?.url) && !_series.poster.url.Contains("placehold"))
                    {
                        <img src="@_series.poster.url" alt="@_series.title" class="cover-image" />
                    }
                    else
                    {
                        <div class="cover-placeholder">
                            <MudIcon Icon="@GetMediaTypeIcon(_series.media_type)" Size="Size.Large" />
                        </div>
                    }
                    <div class="cover-overlay">
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Upload"
                                   OnClick="OpenCoverUploadDialog"
                                   Class="upload-btn">
                            Change Cover
                        </MudButton>
                    </div>
                </div>
                <div class="cover-actions">
                    <MudButton Variant="Variant.Outlined" 
                               Size="Size.Small" 
                               StartIcon="@Icons.Material.Filled.Link"
                               OnClick="OpenCoverUrlDialog"
                               Class="mt-2"
                               FullWidth="true">
                        Set from URL
                    </MudButton>
                </div>
            </div>

            @* Right Side: Details Form *@
            <div class="details-form">
                @* Title Section *@
                <div class="form-section">
                    <h3 class="section-title">Basic Information</h3>
                    
                    <MudTextField T="string" 
                                  @bind-Value="_editModel.Title"
                                  Label="Title"
                                  Variant="Variant.Outlined"
                                  Class="dark-input mb-3"
                                  Required="true" />
                    
                    <div class="alt-titles-section mb-3">
                        <MudText Typo="Typo.caption" Class="field-label">Alternative Titles</MudText>
                        <div class="alt-titles-list">
                            @foreach (var (altTitle, index) in _editModel.AltTitles.Select((t, i) => (t, i)))
                            {
                                <div class="alt-title-item">
                                    <span>@altTitle</span>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                                   Size="Size.Small" 
                                                   OnClick="@(() => RemoveAltTitle(index))"
                                                   Class="remove-btn" />
                                </div>
                            }
                        </div>
                        <div class="add-alt-title">
                            <MudTextField T="string" 
                                          @bind-Value="_newAltTitle"
                                          Placeholder="Add alternative title..."
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="dark-input flex-1" />
                            <MudIconButton Icon="@Icons.Material.Filled.Add" 
                                           Color="Color.Primary"
                                           OnClick="AddAltTitle"
                                           Disabled="@string.IsNullOrWhiteSpace(_newAltTitle)" />
                        </div>
                    </div>

                    <div class="form-row">
                        <MudSelect T="string" 
                                   @bind-Value="_editModel.MediaType"
                                   Label="Media Type"
                                   Variant="Variant.Outlined"
                                   Class="dark-input">
                            @foreach (var type in MediaTypes.All)
                            {
                                <MudSelectItem Value="@type">
                                    <div class="d-flex align-center gap-2">
                                        <MudIcon Icon="@GetMediaTypeIcon(type)" Size="Size.Small" />
                                        @type
                                    </div>
                                </MudSelectItem>
                            }
                        </MudSelect>
                        
                        <MudSelect T="string" 
                                   @bind-Value="_editModel.Status"
                                   Label="Status"
                                   Variant="Variant.Outlined"
                                   Class="dark-input">
                            <MudSelectItem Value="@("")">Unknown</MudSelectItem>
                            <MudSelectItem Value="@("Ongoing")">Ongoing</MudSelectItem>
                            <MudSelectItem Value="@("Completed")">Completed</MudSelectItem>
                            <MudSelectItem Value="@("Hiatus")">Hiatus</MudSelectItem>
                            <MudSelectItem Value="@("Cancelled")">Cancelled</MudSelectItem>
                        </MudSelect>
                    </div>

                    <div class="form-row">
                        <MudNumericField T="int?" 
                                         @bind-Value="_editModel.Year"
                                         Label="Year"
                                         Variant="Variant.Outlined"
                                         Min="1900"
                                         Max="2100"
                                         Class="dark-input" />
                        
                        <MudSelect T="string" 
                                   @bind-Value="_editModel.ReadingDirection"
                                   Label="Reading Direction"
                                   Variant="Variant.Outlined"
                                   Class="dark-input">
                            <MudSelectItem Value="@("ltr")">Left to Right</MudSelectItem>
                            <MudSelectItem Value="@("rtl")">Right to Left</MudSelectItem>
                            <MudSelectItem Value="@("vertical")">Vertical</MudSelectItem>
                        </MudSelect>
                    </div>
                </div>

                <div class="section-divider"></div>

                @* Description *@
                <div class="form-section">
                    <h3 class="section-title">Description</h3>
                    <MudTextField T="string" 
                                  @bind-Value="_editModel.Description"
                                  Label="Description"
                                  Variant="Variant.Outlined"
                                  Lines="4"
                                  Class="dark-input" />
                </div>

                <div class="section-divider"></div>

                @* Groups *@
                <div class="form-section">
                    <h3 class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.Workspaces" Size="Size.Small" Class="mr-2" />
                        Groups
                    </h3>
                    <div class="tag-list">
                        @foreach (var group in _editModel.Groups)
                        {
                            <div class="tag-chip group">
                                <span>@group.name</span>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                               Size="Size.Small"
                                               OnClick="@(() => _editModel.Groups.Remove(group))"
                                               Class="remove-chip" />
                            </div>
                        }
                    </div>
                    <div class="add-tag-row">
                        <MudAutocomplete T="string"
                                         @bind-Value="_newGroupName"
                                         SearchFunc="SearchGroups"
                                         Placeholder="Add group..."
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         ResetValueOnEmptyText="true"
                                         CoerceText="false"
                                         Class="dark-input flex-1" />
                        <MudIconButton Icon="@Icons.Material.Filled.Add" 
                                       Color="Color.Primary"
                                       OnClick="AddGroup"
                                       Disabled="@string.IsNullOrWhiteSpace(_newGroupName)" />
                    </div>
                </div>

                <div class="section-divider"></div>

                @* Authors *@
                <div class="form-section">
                    <h3 class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-2" />
                        Authors
                    </h3>
                    <div class="tag-list">
                        @foreach (var author in _editModel.Authors)
                        {
                            <div class="tag-chip author">
                                <span>@author.name</span>
                                @if (!string.IsNullOrEmpty(author.role))
                                {
                                    <span class="role">(@author.role)</span>
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                               Size="Size.Small"
                                               OnClick="@(() => _editModel.Authors.Remove(author))"
                                               Class="remove-chip" />
                            </div>
                        }
                    </div>
                    <div class="add-tag-row author-row">
                        <MudAutocomplete T="string"
                                         @bind-Value="_newAuthorName"
                                         SearchFunc="SearchAuthors"
                                         Placeholder="Author name..."
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         ResetValueOnEmptyText="true"
                                         CoerceText="false"
                                         Class="dark-input" />
                        <MudSelect T="string" 
                                   @bind-Value="_newAuthorRole"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="role-select dark-input">
                            <MudSelectItem Value="@("Author")">Author</MudSelectItem>
                            <MudSelectItem Value="@("Artist")">Artist</MudSelectItem>
                            <MudSelectItem Value="@("Author & Artist")">Both</MudSelectItem>
                        </MudSelect>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" 
                                       Color="Color.Primary"
                                       OnClick="AddAuthor"
                                       Disabled="@string.IsNullOrWhiteSpace(_newAuthorName)" />
                    </div>
                </div>

                <div class="section-divider"></div>

                @* Scanlators *@
                <div class="form-section">
                    <h3 class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Small" Class="mr-2" />
                        Scanlators / Translation Groups
                    </h3>
                    <div class="tag-list">
                        @foreach (var scanlator in _editModel.Scanlators)
                        {
                            <div class="tag-chip scanlator">
                                <span>@scanlator.name</span>
                                <span class="role">(@FormatScanlatorRole(scanlator.role))</span>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                               Size="Size.Small"
                                               OnClick="@(() => _editModel.Scanlators.Remove(scanlator))"
                                               Class="remove-chip" />
                            </div>
                        }
                    </div>
                    <div class="add-tag-row scanlator-row">
                        <MudAutocomplete T="string"
                                         @bind-Value="_newScanlatorName"
                                         SearchFunc="SearchScanlators"
                                         Placeholder="Scanlator name..."
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         ResetValueOnEmptyText="true"
                                         CoerceText="false"
                                         Class="dark-input" />
                        <MudSelect T="ScanlatorRole" 
                                   @bind-Value="_newScanlatorRole"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="role-select dark-input">
                            <MudSelectItem Value="ScanlatorRole.Translation">Translation</MudSelectItem>
                            <MudSelectItem Value="ScanlatorRole.Scanlation">Scanlation</MudSelectItem>
                            <MudSelectItem Value="ScanlatorRole.Both">Both</MudSelectItem>
                        </MudSelect>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" 
                                       Color="Color.Primary"
                                       OnClick="AddScanlator"
                                       Disabled="@string.IsNullOrWhiteSpace(_newScanlatorName)" />
                    </div>
                </div>

                <div class="section-divider"></div>

                @* Tags *@
                <div class="form-section">
                    <h3 class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" Class="mr-2" />
                        Tags
                    </h3>
                    <div class="tag-list">
                        @foreach (var tag in _editModel.Tags)
                        {
                            <div class="tag-chip genre">
                                <span>@tag</span>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                               Size="Size.Small"
                                               OnClick="@(() => _editModel.Tags.Remove(tag))"
                                               Class="remove-chip" />
                            </div>
                        }
                    </div>
                    <div class="add-tag-row">
                        <MudAutocomplete T="string"
                                         @bind-Value="_newTag"
                                         SearchFunc="SearchTags"
                                         Placeholder="Add tag..."
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         ResetValueOnEmptyText="true"
                                         CoerceText="false"
                                         Class="dark-input flex-1" />
                        <MudIconButton Icon="@Icons.Material.Filled.Add" 
                                       Color="Color.Primary"
                                       OnClick="AddTag"
                                       Disabled="@string.IsNullOrWhiteSpace(_newTag)" />
                    </div>
                </div>

                <div class="section-divider"></div>

                @* Content Warnings *@
                <div class="form-section">
                    <h3 class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-2" />
                        Content Warnings
                    </h3>
                    <div class="warning-chips">
                        @foreach (var warning in ContentWarnings.All)
                        {
                            var isSelected = _editModel.ContentWarnings.Contains(warning);
                            <div class="warning-chip @(isSelected ? "selected" : "")" 
                                 @onclick="@(() => ToggleContentWarning(warning))">
                                <MudIcon Icon="@GetWarningIcon(warning)" Size="Size.Small" />
                                <span>@FormatWarning(warning)</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="section-divider"></div>

                @* Localized Metadata (i18n) *@
                <div class="form-section">
                    <h3 class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.Translate" Size="Size.Small" Class="mr-2" />
                        Localized Versions
                    </h3>
                    <MudText Typo="Typo.caption" Class="mb-3" Style="color: rgba(255,255,255,0.5);">
                        Add translations with language-specific metadata and scanlation groups
                    </MudText>
                    
                    <div class="localized-versions-grid">
                        @foreach (var lang in _editModel.Localized.Keys.ToList())
                        {
                            <div class="localized-card">
                                <div class="localized-card-header">
                                    <div class="lang-badge">
                                        <MudIcon Icon="@Icons.Material.Filled.Language" Size="Size.Small" />
                                        <span>@GetLanguageName(lang)</span>
                                        <span class="lang-code">(@lang)</span>
                                    </div>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   Class="delete-lang-btn"
                                                   OnClick="@(() => RemoveLocalization(lang))" />
                                </div>
                                
                                <div class="localized-card-body">
                                    <MudTextField T="string" 
                                                  Value="@_editModel.Localized[lang].Title"
                                                  ValueChanged="@(v => UpdateLocalizedTitle(lang, v))"
                                                  Label="Title"
                                                  Placeholder="Translated title..."
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Class="dark-input mb-3" />
                                    <MudTextField T="string" 
                                                  Value="@_editModel.Localized[lang].Description"
                                                  ValueChanged="@(v => UpdateLocalizedDescription(lang, v))"
                                                  Label="Description"
                                                  Placeholder="Translated description..."
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Lines="3"
                                                  Class="dark-input mb-3" />
                                    
                                    @* Scanlators for this language *@
                                    <div class="localized-scanlators-section">
                                        <div class="scanlators-header">
                                            <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Small" />
                                            <span>Translation/Scanlation Groups</span>
                                        </div>
                                        
                                        @if (_editModel.Localized[lang].Scanlators.Count > 0)
                                        {
                                            <div class="scanlator-chips">
                                                @foreach (var scanlator in _editModel.Localized[lang].Scanlators)
                                                {
                                                    <MudChip T="string" 
                                                             Size="Size.Small" 
                                                             Color="Color.Primary"
                                                             OnClose="@(() => RemoveLocalizedScanlator(lang, scanlator))">
                                                        @scanlator.name
                                                    </MudChip>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Class="no-scanlators-text">
                                                No scanlators assigned
                                            </MudText>
                                        }
                                        
                                        <div class="add-scanlator-input">
                                            <MudAutocomplete T="string"
                                                             @bind-Value="@_newLocalizedScanlatorName"
                                                             SearchFunc="@((v, t) => SearchScanlators(v, t))"
                                                             Placeholder="Add scanlator..."
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             Class="dark-input" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Add"
                                                           Color="Color.Primary"
                                                           Size="Size.Small"
                                                           OnClick="@(() => AddLocalizedScanlator(lang))"
                                                           Disabled="@string.IsNullOrWhiteSpace(_newLocalizedScanlatorName)" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    
                    @* Add new language *@
                    <div class="add-language-section">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Class="mr-2" Style="color: rgba(255,255,255,0.5);" />
                        <MudSelect T="string" 
                                   @bind-Value="_newLanguage"
                                   Placeholder="Add language..."
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="dark-input add-lang-select">
                            @foreach (var lang in _availableLanguages.Where(l => !_editModel.Localized.ContainsKey(l.Key)))
                            {
                                <MudSelectItem Value="@lang.Key">@lang.Value (@lang.Key)</MudSelectItem>
                            }
                        </MudSelect>
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddLocalization"
                                   Disabled="@string.IsNullOrWhiteSpace(_newLanguage)">
                            Add Language
                        </MudButton>
                    </div>
                </div>

                @* Actions *@
                <div class="form-actions">
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Default"
                               OnClick="ResetChanges"
                               Disabled="@_saving">
                        Reset
                    </MudButton>
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="SaveChanges"
                               Disabled="@_saving">
                        @if (_saving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Saving...</span>
                        }
                        else
                        {
                            <span>Save Changes</span>
                        }
                    </MudButton>
                </div>
            </div>
        </div>
    }
</div>

@* Cover Upload Dialog *@
<MudDialog @bind-Visible="_showCoverUpload" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Upload Cover Image</MudText>
    </TitleContent>
    <DialogContent>
        <MudFileUpload T="IBrowserFile" 
                       Accept=".jpg,.jpeg,.png,.webp,.gif"
                       OnFilesChanged="OnCoverFileSelected"
                       MaximumFileCount="1">
            <ActivatorContent>
                <MudPaper Class="upload-dropzone" Outlined="true">
                    @if (_uploadingCover)
                    {
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                        <MudText Typo="Typo.body2" Class="mt-2">Uploading...</MudText>
                    }
                    else if (_selectedCoverFile != null)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
                        <MudText Typo="Typo.body2" Class="mt-2">@_selectedCoverFile.Name</MudText>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large" Color="Color.Primary" />
                        <MudText Typo="Typo.body1" Class="mt-2">Click to upload or drag & drop</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">JPG, PNG, WebP or GIF (max 10MB)</MudText>
                    }
                </MudPaper>
            </ActivatorContent>
        </MudFileUpload>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="@(() => _showCoverUpload = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   OnClick="UploadCover"
                   Disabled="@(_selectedCoverFile == null || _uploadingCover)">
            Upload
        </MudButton>
    </DialogActions>
</MudDialog>

@* Cover URL Dialog *@
<MudDialog @bind-Visible="_showCoverUrl" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Set Cover from URL</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string" 
                      @bind-Value="_coverUrl"
                      Label="Image URL"
                      Placeholder="https://example.com/image.jpg"
                      Variant="Variant.Outlined"
                      Class="dark-input"
                      FullWidth="true" />
        @if (!string.IsNullOrEmpty(_coverUrl))
        {
            <div class="url-preview mt-3">
                <img src="@_coverUrl" alt="Preview" class="preview-image" @onerror="OnCoverPreviewError" />
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="@(() => _showCoverUrl = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   OnClick="SetCoverFromUrl"
                   Disabled="@string.IsNullOrWhiteSpace(_coverUrl)">
            Set Cover
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .details-page {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .loading-container, .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        color: rgba(255, 255, 255, 0.7);
    }

    .nav-row {
        margin-bottom: 1.5rem;
    }

    .back-btn {
        color: rgba(255, 255, 255, 0.7);
    }

    .back-btn:hover {
        color: #c9a66b;
    }

    .details-content {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 2rem;
    }

    /* Cover Section */
    .cover-section {
        position: sticky;
        top: 1rem;
        align-self: start;
    }

    .cover-wrapper {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        aspect-ratio: 2/3;
        background: rgba(255, 255, 255, 0.05);
    }

    .cover-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .cover-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255, 255, 255, 0.3);
    }

    .cover-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s;
    }

    .cover-wrapper:hover .cover-overlay {
        opacity: 1;
    }

    /* Details Form */
    .details-form {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        padding: 1.5rem;
    }

    .form-section {
        margin-bottom: 0;
    }

    .section-title {
        display: flex;
        align-items: center;
        font-size: 0.875rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.8);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0 0 1rem 0;
    }

    .section-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.08);
        margin: 1.5rem 0;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .field-label {
        display: block;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 0.5rem;
    }

    /* Alt Titles */
    .alt-titles-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .alt-title-item {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.25rem 0.5rem 0.25rem 0.75rem;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        font-size: 0.8125rem;
        color: rgba(255, 255, 255, 0.8);
    }

    .alt-title-item .remove-btn {
        padding: 2px;
