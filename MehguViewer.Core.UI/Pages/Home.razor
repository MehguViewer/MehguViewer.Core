@using MehguViewer.Shared.Models

@code {
    private bool _loading = true;
    private bool _hasError = false;
    private bool _editMode = false;
    private bool _isAdmin = false;
    private bool _isUploader = false;
    private SystemStats _stats = new(0, 0, 0);
    private int _seriesCount = 0;
    private Series[] _recentSeries = Array.Empty<Series>();
    private NodeMetadata _nodeMetadata = new("1.0.0", "MehguViewer Node", "", "", new NodeCapabilities(true, true, false), new NodeMaintainer("Admin", ""));
    private DashboardSettings _dashboardSettings = new();
    
    // User stats
    private int _adminCount = 0;
    private int _uploaderCount = 0;
    private int _userCount = 0;
    private User[] _recentUsers = Array.Empty<User>();

    protected override async Task OnInitializedAsync()
    {
        await CheckUserRole();
        await LoadDashboardSettings();
        await LoadStats();
    }

    private async Task CheckUserRole()
    {
        try
        {
            var token = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "authToken");
            if (!string.IsNullOrEmpty(token))
            {
                var parts = token.Split('.');
                if (parts.Length > 1)
                {
                    var payload = System.Text.Encoding.UTF8.GetString(ParseBase64WithoutPadding(parts[1]));
                    var claims = System.Text.Json.JsonDocument.Parse(payload);
                    
                    if (claims.RootElement.TryGetProperty("role", out var roleElement))
                    {
                        var role = roleElement.GetString();
                        _isAdmin = role == "Admin";
                        _isUploader = role == "Uploader";
                    }
                    
                    if (!_isAdmin && claims.RootElement.TryGetProperty("scope", out var scopeElement))
                    {
                        var scopes = scopeElement.GetString() ?? "";
                        _isAdmin = scopes.Contains("mvn:admin");
                    }
                }
            }
        }
        catch
        {
            _isAdmin = false;
            _isUploader = false;
        }
    }

    private static byte[] ParseBase64WithoutPadding(string base64)
    {
        base64 = base64.Replace('-', '+').Replace('_', '/');
        switch (base64.Length % 4)
        {
            case 2: base64 += "=="; break;
            case 3: base64 += "="; break;
        }
        return Convert.FromBase64String(base64);
    }

    private async Task LoadDashboardSettings()
    {
        try
        {
            _dashboardSettings = await DashboardService.GetSettingsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard settings: {ex.Message}");
        }
    }

    private bool IsWidgetVisible(string widgetId)
    {
        var widget = _dashboardSettings.Widgets.FirstOrDefault(w => w.Id == widgetId);
        return widget?.IsVisible ?? true;
    }

    private async Task ToggleWidget(string widgetId)
    {
        var widget = _dashboardSettings.Widgets.FirstOrDefault(w => w.Id == widgetId);
        if (widget != null)
        {
            widget.IsVisible = !widget.IsVisible;
            await DashboardService.SaveSettingsAsync(_dashboardSettings);
            StateHasChanged();
        }
    }

    private async Task ToggleEditMode()
    {
        _editMode = !_editMode;
        if (!_editMode)
        {
            // Save settings when exiting edit mode
            await DashboardService.SaveSettingsAsync(_dashboardSettings);
            Snackbar.Add("Dashboard layout saved!", Severity.Success);
        }
    }

    private async Task LoadStats()
    {
        if (_loading && _hasError) return; // Prevent repeated error loading
        
        _loading = true;
        _hasError = false;
        StateHasChanged();
        
        try
        {
            // Load data with individual error handling
            try
            {
                var stats = await Http.GetFromJsonAsync<SystemStats>("api/v1/admin/stats");
                if (stats != null) _stats = stats;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Stats API error: {ex.Message}");
            }

            try
            {
                var seriesResponse = await Http.GetFromJsonAsync<SeriesListResponse>("api/v1/series?limit=5");
                if (seriesResponse?.data != null)
                {
                    _recentSeries = seriesResponse.data;
                    _seriesCount = _recentSeries.Length;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Series API error: {ex.Message}");
            }

            try
            {
                var metadata = await Http.GetFromJsonAsync<NodeMetadata>(".well-known/mehgu-node");
                if (metadata != null) _nodeMetadata = metadata;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Metadata API error: {ex.Message}");
            }

            // Load user stats (admin only)
            if (_isAdmin)
            {
                try
                {
                    var users = await Http.GetFromJsonAsync<User[]>("api/v1/users");
                    if (users != null)
                    {
                        _adminCount = users.Count(u => u.role == "Admin");
                        _uploaderCount = users.Count(u => u.role == "Uploader");
                        _userCount = users.Count(u => u.role == "User");
                        _recentUsers = users.OrderByDescending(u => u.created_at).Take(3).ToArray();
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Users API error: {ex.Message}");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading stats: {ex.Message}");
            _hasError = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private string FormatUptime(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        if (ts.TotalDays >= 1)
            return $"{(int)ts.TotalDays}d {ts.Hours}h";
        if (ts.TotalHours >= 1)
            return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        return $"{ts.Minutes}m {ts.Seconds}s";
    }

    private string TruncateId(string id)
    {
        if (id.Length > 24)
            return id.Substring(0, 24) + "...";
        return id;
    }
}
