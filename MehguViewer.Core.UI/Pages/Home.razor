@page "/"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@using MehguViewer.Core.UI.Services
@inject DashboardSettingsService DashboardService

<PageTitle>Dashboard - MehguViewer Core</PageTitle>

<div class="dashboard-container">
    @* Animated Background *@
    <div class="dashboard-bg"></div>
    
    @* Header Section *@
    <div class="dashboard-header">
        <div class="header-content">
            <div class="header-text">
                <h1 class="header-title">Dashboard</h1>
                <p class="header-subtitle">Welcome back! Here's what's happening with your node.</p>
            </div>
            <div class="header-actions">
                @if (_isAdmin)
                {
                    <button class="action-btn @(_editMode ? "edit-active" : "secondary")" @onclick="ToggleEditMode">
                        <MudIcon Icon="@(_editMode ? Icons.Material.Filled.Check : Icons.Material.Filled.Edit)" Size="Size.Small" />
                        <span>@(_editMode ? "Done Editing" : "Edit Dashboard")</span>
                    </button>
                }
                <button class="action-btn secondary" @onclick="LoadStats" disabled="@_loading">
                    <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Class="@(_loading ? "spin" : "")" />
                    <span>Refresh</span>
                </button>
                @if (_isAdmin || _isUploader)
                {
                    <a class="action-btn primary" href="/ingest">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                        <span>New Upload</span>
                    </a>
                }
            </div>
        </div>
    </div>

    @if (_editMode && _isAdmin)
    {
        <div class="edit-mode-banner">
            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
            <span>Edit Mode: Toggle widgets on/off to customize your dashboard</span>
        </div>
    }

    @* Stats Cards Grid - Only visible to Admin *@
    @if (_isAdmin && IsWidgetVisible("stats"))
    {
        <div class="widget-wrapper @(_editMode ? "editable" : "")">
            @if (_editMode)
            {
                <div class="widget-edit-overlay">
                    <button class="widget-toggle-btn" @onclick="@(() => ToggleWidget("stats"))">
                        <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small" />
                        <span>Hide Statistics</span>
                    </button>
                </div>
            }
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon users">
                        <MudIcon Icon="@Icons.Material.Filled.People" />
                    </div>
                    <div class="stat-content">
                        <span class="stat-label">Total Users</span>
                        <span class="stat-value">@_stats.total_users</span>
                        <span class="stat-badge success">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                            Active
                        </span>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon series">
                        <MudIcon Icon="@Icons.Material.Filled.MenuBook" />
                    </div>
                    <div class="stat-content">
                        <span class="stat-label">Total Series</span>
                        <span class="stat-value">@_seriesCount</span>
                        <span class="stat-badge info">
                            <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Size="Size.Small" />
                            In Library
                        </span>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon storage">
                        <MudIcon Icon="@Icons.Material.Filled.CloudQueue" />
                    </div>
                    <div class="stat-content">
                        <span class="stat-label">Storage Used</span>
                        <span class="stat-value">@FormatBytes(_stats.total_storage_bytes)</span>
                        <span class="stat-badge warning">
                            <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" />
                            Total Size
                        </span>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon uptime">
                        <MudIcon Icon="@Icons.Material.Filled.Speed" />
                    </div>
                    <div class="stat-content">
                        <span class="stat-label">Uptime</span>
                        <span class="stat-value">@FormatUptime(_stats.uptime_seconds)</span>
                        <span class="stat-badge success">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                            Online
                        </span>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (_editMode && _isAdmin)
    {
        <div class="hidden-widget-placeholder" @onclick="@(() => ToggleWidget("stats"))">
            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Large" />
            <span>Statistics (Hidden)</span>
            <button class="show-widget-btn">
                <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                Show
            </button>
        </div>
    }

    @* Main Content Grid *@
    <div class="content-grid">
        @* Recent Series Card *@
        @if (IsWidgetVisible("recent-series"))
        {
            <div class="widget-wrapper @(_editMode ? "editable" : "") main-card">
                @if (_editMode)
                {
                    <div class="widget-edit-overlay">
                        <button class="widget-toggle-btn" @onclick="@(() => ToggleWidget("recent-series"))">
                            <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small" />
                            <span>Hide Recent Series</span>
                        </button>
                    </div>
                }
                <div class="glass-card">
                    <div class="card-header">
                        <h2 class="card-title">Recent Series</h2>
                        <a href="/series" class="view-all-link">
                            View All
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                        </a>
                    </div>
                    
                    <div class="card-body">
                        @if (_loading)
                        {
                            <div class="loading-state">
                                <div class="loader"></div>
                                <span>Loading data...</span>
                            </div>
                        }
                        else if (_recentSeries.Length == 0)
                        {
                            <div class="empty-state">
                                <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Size="Size.Large" />
                                <p>No series yet</p>
                                <span>Start by uploading your first content!</span>
                            </div>
                        }
                        else
                        {
                            <div class="series-list">
                                @foreach (var series in _recentSeries)
                                {
                                    <div class="series-item">
                                        <div class="series-avatar">
                                            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" />
                                        </div>
                                        <div class="series-info">
                                            <span class="series-title">@series.title</span>
                                            <span class="series-id">@TruncateId(series.id)</span>
                                        </div>
                                        <span class="series-type @series.media_type?.ToLower()">@series.media_type</span>
                                        <span class="series-status active">Active</span>
                                        <div class="series-actions">
                                            <button class="icon-btn"><MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" /></button>
                                            <button class="icon-btn"><MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" /></button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else if (_editMode)
        {
            <div class="hidden-widget-placeholder main-card" @onclick="@(() => ToggleWidget("recent-series"))">
                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Large" />
                <span>Recent Series (Hidden)</span>
                <button class="show-widget-btn">
                    <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                    Show
                </button>
            </div>
        }

        @* Sidebar *@
        <div class="sidebar">
            @* Quick Actions Card *@
            @if (IsWidgetVisible("quick-actions"))
            {
                <div class="widget-wrapper @(_editMode ? "editable" : "")">
                    @if (_editMode)
                    {
                        <div class="widget-edit-overlay">
                            <button class="widget-toggle-btn" @onclick="@(() => ToggleWidget("quick-actions"))">
                                <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small" />
                                <span>Hide</span>
                            </button>
                        </div>
                    }
                    <div class="glass-card">
                        <h2 class="card-title">Quick Actions</h2>
                        <div class="quick-actions">
                            <a href="/series/new" class="quick-action-btn">
                                <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                                <span>Create New Series</span>
                            </a>
                            <a href="/ingest" class="quick-action-btn">
                                <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Small" />
                                <span>Bulk Upload</span>
                            </a>
                            <a href="/users" class="quick-action-btn">
                                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" />
                                <span>Manage Users</span>
                            </a>
                            <a href="/settings" class="quick-action-btn">
                                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" />
                                <span>System Settings</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
            else if (_editMode)
            {
                <div class="hidden-widget-placeholder small" @onclick="@(() => ToggleWidget("quick-actions"))">
                    <MudIcon Icon="@Icons.Material.Filled.FlashOn" Size="Size.Medium" />
                    <span>Quick Actions (Hidden)</span>
                    <button class="show-widget-btn small">
                        <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                    </button>
                </div>
            }

            @* Node Info Card *@
            @if (IsWidgetVisible("node-info"))
            {
                <div class="widget-wrapper @(_editMode ? "editable" : "")">
                    @if (_editMode)
                    {
                        <div class="widget-edit-overlay">
                            <button class="widget-toggle-btn" @onclick="@(() => ToggleWidget("node-info"))">
                                <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small" />
                                <span>Hide</span>
                            </button>
                        </div>
                    }
                    <div class="glass-card">
                        <h2 class="card-title">Node Information</h2>
                        <div class="node-info">
                            <div class="info-row">
                                <span class="info-label">Node Name</span>
                                <span class="info-value">@_nodeMetadata.node_name</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Version</span>
                                <span class="version-badge">@_nodeMetadata.version</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Capabilities</span>
                                <div class="capabilities">
                                    @if (_nodeMetadata.capabilities?.search == true)
                                    {
                                        <span class="capability-icon" title="Search">
                                            <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                                        </span>
                                    }
                                    @if (_nodeMetadata.capabilities?.streaming == true)
                                    {
                                        <span class="capability-icon" title="Streaming">
                                            <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" />
                                        </span>
                                    }
                                    @if (_nodeMetadata.capabilities?.download == true)
                                    {
                                        <span class="capability-icon" title="Download">
                                            <MudIcon Icon="@Icons.Material.Filled.Download" Size="Size.Small" />
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Auth Server</span>
                                <span class="info-value truncate" title="@_nodeMetadata.auth_server">
                                    <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" />
                                    Connected
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (_editMode)
            {
                <div class="hidden-widget-placeholder small" @onclick="@(() => ToggleWidget("node-info"))">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Medium" />
                    <span>Node Info (Hidden)</span>
                    <button class="show-widget-btn small">
                        <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                    </button>
                </div>
            }

            @* Users Overview Card *@
            @if (_isAdmin && IsWidgetVisible("users-overview"))
            {
                <div class="widget-wrapper @(_editMode ? "editable" : "")">
                    @if (_editMode)
                    {
                        <div class="widget-edit-overlay">
                            <button class="widget-toggle-btn" @onclick="@(() => ToggleWidget("users-overview"))">
                                <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small" />
                                <span>Hide</span>
                            </button>
                        </div>
                    }
                    <div class="glass-card">
                        <div class="card-header">
                            <h2 class="card-title">Users Overview</h2>
                            <a href="/users" class="view-all-link">
                                Manage
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </a>
                        </div>
                        <div class="user-stats-grid">
                            <div class="user-stat-item admin">
                                <div class="user-stat-icon">
                                    <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Small" />
                                </div>
                                <div class="user-stat-content">
                                    <span class="user-stat-value">@_adminCount</span>
                                    <span class="user-stat-label">Admins</span>
                                </div>
                            </div>
                            <div class="user-stat-item uploader">
                                <div class="user-stat-icon">
                                    <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Small" />
                                </div>
                                <div class="user-stat-content">
                                    <span class="user-stat-value">@_uploaderCount</span>
                                    <span class="user-stat-label">Uploaders</span>
                                </div>
                            </div>
                            <div class="user-stat-item user">
                                <div class="user-stat-icon">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                </div>
                                <div class="user-stat-content">
                                    <span class="user-stat-value">@_userCount</span>
                                    <span class="user-stat-label">Users</span>
                                </div>
                            </div>
                        </div>
                        @if (_recentUsers.Length > 0)
                        {
                            <div class="recent-users-list">
                                <span class="recent-users-title">Recent Users</span>
                                @foreach (var user in _recentUsers.Take(3))
                                {
                                    <div class="recent-user-item">
                                        <div class="recent-user-avatar @user.role.ToLower()">
                                            @user.username.ToUpper()[0]
                                        </div>
                                        <div class="recent-user-info">
                                            <span class="recent-user-name">@user.username</span>
                                            <span class="recent-user-role @user.role.ToLower()">@user.role</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else if (_editMode && _isAdmin)
            {
                <div class="hidden-widget-placeholder small" @onclick="@(() => ToggleWidget("users-overview"))">
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Medium" />
                    <span>Users Overview (Hidden)</span>
                    <button class="show-widget-btn small">
                        <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* Base Container */
    .dashboard-container {
        position: relative;
        min-height: 100%;
        padding: 0;
    }

    /* Animated Background */
    .dashboard-bg {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(-45deg, #0a0a0a, #121210, #0d0d0b, #151512);
        background-size: 400% 400%;
        animation: gradientBG 15s ease infinite;
        z-index: -1;
    }

    @@keyframes gradientBG {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    /* Header */
    .dashboard-header {
        margin-bottom: 2rem;
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .header-title {
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
        margin: 0;
        letter-spacing: -0.02em;
    }

    .header-subtitle {
        color: rgba(255, 255, 255, 0.6);
        margin: 0.25rem 0 0;
        font-size: 0.95rem;
    }

    .header-actions {
        display: flex;
        gap: 0.75rem;
    }

    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        border-radius: 10px;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
        border: none;
    }

    .action-btn.primary {
        background: linear-gradient(135deg, #c9a66b, #8b6914);
        color: #fff;
    }

    .action-btn.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(201, 166, 107, 0.35);
    }

    .action-btn.secondary {
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .action-btn.secondary:hover {
        background: rgba(255, 255, 255, 0.12);
        border-color: rgba(255, 255, 255, 0.2);
    }

    .action-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .spin {
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* Stats Grid */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 1200px) {
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 600px) {
        .stats-grid { grid-template-columns: 1fr; }
    }

    .stat-card {
        background: rgba(13, 13, 13, 0.85);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border: 1px solid rgba(201, 166, 107, 0.1);
        border-radius: 16px;
        padding: 1.5rem;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .stat-card:hover {
        border-color: rgba(201, 166, 107, 0.25);
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-icon.users { background: linear-gradient(135deg, rgba(201, 166, 107, 0.2), rgba(201, 166, 107, 0.1)); color: #c9a66b; }
    .stat-icon.series { background: linear-gradient(135deg, rgba(232, 212, 184, 0.2), rgba(232, 212, 184, 0.1)); color: #e8d4b8; }
    .stat-icon.storage { background: linear-gradient(135deg, rgba(139, 105, 20, 0.2), rgba(139, 105, 20, 0.1)); color: #c9a66b; }
    .stat-icon.uptime { background: linear-gradient(135deg, rgba(34, 197, 94, 0.2), rgba(34, 197, 94, 0.1)); color: #22c55e; }

    .stat-content {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        flex: 1;
        min-width: 0;
    }

    .stat-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: rgba(255, 255, 255, 0.5);
    }

    .stat-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: #fff;
        line-height: 1.2;
    }

    .stat-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.7rem;
        font-weight: 500;
        margin-top: 0.25rem;
    }

    .stat-badge.success { color: #22c55e; }
    .stat-badge.info { color: #3b82f6; }
    .stat-badge.warning { color: #f59e0b; }

    /* Content Grid */
    .content-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 1.5rem;
    }

    @@media (max-width: 1024px) {
        .content-grid { grid-template-columns: 1fr; }
    }

    /* Glass Card */
    .glass-card {
        background: rgba(13, 13, 13, 0.85);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border: 1px solid rgba(201, 166, 107, 0.1);
        border-radius: 16px;
        padding: 1.5rem;
        overflow: hidden;
        min-width: 0;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.25rem;
    }

    .card-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #fff;
        margin: 0;
    }

    .view-all-link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        color: #c9a66b;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.2s;
    }

    .view-all-link:hover {
        color: #e8d4b8;
    }

    /* Loading & Empty States */
    .loading-state, .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem;
        gap: 1rem;
        color: rgba(255, 255, 255, 0.5);
    }

    .loader {
        width: 32px;
        height: 32px;
        border: 3px solid rgba(255, 255, 255, 0.1);
        border-top-color: #c9a66b;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .empty-state p {
        font-size: 1rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.7);
        margin: 0;
    }

    .empty-state span {
        font-size: 0.875rem;
    }

    /* Series List */
    .series-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .series-item {
        display: grid;
        grid-template-columns: auto 1fr auto auto auto;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        transition: background 0.2s;
    }

    .series-item:hover {
        background: rgba(255, 255, 255, 0.06);
    }

    .series-avatar {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: linear-gradient(135deg, rgba(201, 166, 107, 0.2), rgba(201, 166, 107, 0.1));
        color: #c9a66b;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .series-info {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .series-title {
        font-weight: 500;
        color: #fff;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .series-id {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.4);
    }

    .series-type {
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: capitalize;
    }

