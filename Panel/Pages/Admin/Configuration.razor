@page "/admin/configuration"
@inject HttpClient Http

<h3>System Configuration</h3>

@if (config == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <label class="form-label">MOTD Message</label>
        <input type="text" class="form-control" @bind="config.motd_message" />
    </div>

    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" @bind="config.registration_open" id="regOpen">
        <label class="form-check-label" for="regOpen">
            Registration Open
        </label>
    </div>

    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" @bind="config.maintenance_mode" id="maintMode">
        <label class="form-check-label" for="maintMode">
            Maintenance Mode
        </label>
    </div>

    <button class="btn btn-primary" @onclick="SaveConfig">Save Changes</button>
}

@code {
    private SystemConfig? config;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            config = await Http.GetFromJsonAsync<SystemConfig>("/api/v1/admin/configuration");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading config: {ex.Message}");
            // Mock data for now if backend is not running or fails
            config = new SystemConfig
            {
                motd_message = "Welcome to MehguViewer",
                registration_open = true,
                maintenance_mode = false,
                default_language_filter = new[] { "en" }
            };
        }
    }

    private async Task SaveConfig()
    {
        // await Http.PutAsJsonAsync("/api/v1/admin/configuration", config);
        Console.WriteLine("Configuration saved (mock)");
    }

    public class SystemConfig
    {
        public bool registration_open { get; set; }
        public bool maintenance_mode { get; set; }
        public string motd_message { get; set; } = "";
        public string[] default_language_filter { get; set; } = Array.Empty<string>();
    }
}
