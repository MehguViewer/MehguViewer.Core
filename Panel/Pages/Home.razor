@page "/"

<PageTitle>MehguViewer Panel</PageTitle>

<h1>MehguViewer Admin Panel</h1>

<p>Welcome to the administration panel for your MehguViewer node.</p>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Setup Wizard</h5>
                <p class="card-text">Run the initial setup wizard.</p>
                <a href="wizard" class="btn btn-primary">Go to Wizard</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Configuration</h5>
                <p class="card-text">Manage system settings.</p>
                <a href="admin/configuration" class="btn btn-secondary">Manage Config</a>
            </div>
        </div>
    </div>
</div>
