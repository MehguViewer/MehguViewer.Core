@page "/wizard"
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>Setup Wizard</h3>

@if (step == 1)
{
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Welcome to MehguViewer</h5>
            <p class="card-text">This wizard will help you configure your new MehguViewer node.</p>
            <button class="btn btn-primary" @onclick="NextStep">Get Started</button>
        </div>
    </div>
}
else if (step == 2)
{
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Create Admin Account</h5>
            <div class="mb-3">
                <label class="form-label">Username</label>
                <input type="text" class="form-control" @bind="username" />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" class="form-control" @bind="password" />
            </div>
            <button class="btn btn-secondary" @onclick="PrevStep">Back</button>
            <button class="btn btn-primary" @onclick="NextStep">Next</button>
        </div>
    </div>
}
else if (step == 3)
{
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Finish Setup</h5>
            <p>You are all set!</p>
            <button class="btn btn-secondary" @onclick="PrevStep">Back</button>
            <button class="btn btn-success" @onclick="FinishSetup">Finish</button>
        </div>
    </div>
}

@code {
    private int step = 1;
    private string username = "";
    private string password = "";

    private void NextStep()
    {
        step++;
    }

    private void PrevStep()
    {
        step--;
    }

    private async Task FinishSetup()
    {
        // In a real app, we would post the data to the backend here.
        // await Http.PostAsJsonAsync("/api/v1/setup", new { username, password });
        Navigation.NavigateTo("/");
    }
}
