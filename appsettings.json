{
  "EmbeddedPostgres": {
    "Enabled": true,
    "Version": "15.3.0",
    "Port": 6236,
    "DataDir": "pg_data"
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Auth": {
    "RegistrationOpen": true,
    "AllowPanelAccessForUsers": false,
    "MaxLoginAttempts": 5,
    "LockoutDurationMinutes": 15,
    "TokenExpiryHours": 24,
    "Cloudflare": {
      "Enabled": false,
      "TurnstileSiteKey": "",
      "TurnstileSecretKey": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}